#!/usr/bin/env bash
#
# claudevm — manage per-project Lima sandbox VMs for Claude Code sessions.
#
# Setup (once):
#   ./install.sh
#
# Per project:
#   claudevm new myproject ~/code/myproject     # create config (doesn't boot yet)
#   claudevm allow myproject                    # optional: edit domain allowlist
#   claudevm secrets myproject                  # if the VM needs a Claude Code token or GitHub
#                                                # access (push/pull, PRs, Issues/Projects API),
#                                                # saves a scoped Claude token + GitHub PAT
#   claudevm up myproject                       # boot the VM
#   claudevm code myproject                     # open VS Code Remote-SSH into it
#   ...work...
#   claudevm down myproject                     # stop (keeps disk state)
#   claudevm rm myproject                       # stop + delete VM + delete config
#
set -euo pipefail

CLAUDEVM_HOME="${CLAUDEVM_HOME:-$HOME/.config/claudevm}"
TEMPLATE="$CLAUDEVM_HOME/claude-sandbox.yaml"
DEFAULT_ALLOWLIST="$CLAUDEVM_HOME/default-allowlist.txt"
INSTANCES_DIR="${CLAUDEVM_INSTANCES:-$HOME/.local/var/claudevm/instances}"

CPUS="${CLAUDEVM_CPUS:-4}"
MEMORY="${CLAUDEVM_MEMORY:-4}"   # GiB
DISK="${CLAUDEVM_DISK:-60}"      # GiB

usage() {
  cat <<EOF
Usage: claudevm <command> [args]

  new <name> <project-dir>   Create config for a new sandbox
  allow <name>                Edit the domain allowlist for a sandbox (\$EDITOR)
  secrets <name>               Save a Claude Code token + (optional) GitHub token
  up <name>                   Boot (or resume) the sandbox VM
  down <name>                 Stop the VM (disk state is kept)
  rm <name>                   Stop, delete the VM, and delete its config
  ssh <name>                  Shell into the VM
  code <name>                 Open VS Code (Remote-SSH) into /workspace on the VM
  refresh <name>               Re-run the firewall/allowlist refresh immediately
  ls                           List all Lima VMs (claudevm-managed and otherwise)
EOF
}

require_instance() {
  local name="$1"
  if [ ! -d "$INSTANCES_DIR/$name" ]; then
    echo "No config found for '$name'. Run: claudevm new $name <project-dir>" >&2
    exit 1
  fi
}

close_ssh_control() {
  # Lima opens its own SSH connection early in boot to run provisioning, and
  # (ControlPersist yes) keeps reusing it for later `claudevm ssh`/`limactl
  # shell`/VS Code sessions. /etc/environment is a file on the guest's own
  # disk, so at the moment that connection is opened it still holds
  # whatever the *previous* boot last wrote -- this boot's provisioning
  # hasn't run yet. That connection's session env is fixed at open time, so
  # it keeps serving that stale snapshot indefinitely. Force it closed right
  # after `up` finishes (provisioning is done by then), so the next
  # connection is guaranteed fresh instead of reusing the early one.
  local name="$1"
  local ssh_cfg="$HOME/.lima/$name/ssh.config"
  if [ -f "$ssh_cfg" ]; then
    ssh -O exit -F "$ssh_cfg" "lima-$name" >/dev/null 2>&1 || true
  fi
}

cmd_new() {
  local name="${1:?instance name required}"
  local project_dir="${2:?project directory required}"
  project_dir="$(cd "$project_dir" && pwd)"

  [ -f "$TEMPLATE" ] || { echo "Missing $TEMPLATE — copy claude-sandbox.yaml into $CLAUDEVM_HOME first." >&2; exit 1; }

  local cfg_dir="$INSTANCES_DIR/$name"
  mkdir -p "$cfg_dir"
  cp "$DEFAULT_ALLOWLIST" "$cfg_dir/allowlist.txt"
  echo "$project_dir" > "$cfg_dir/project-dir"

  if [ -f "$HOME/.gitconfig" ]; then
    cp "$HOME/.gitconfig" "$cfg_dir/gitconfig"
  fi
  if [ -f "$HOME/.vimrc" ]; then
    cp "$HOME/.vimrc" "$cfg_dir/vimrc"
  fi

  echo "Created sandbox config: $name"
  echo "  Project dir:  $project_dir"
  echo "  Allowlist:    $cfg_dir/allowlist.txt  (edit with: claudevm allow $name)"
  echo "Next: claudevm up $name"
}

cmd_up() {
  local name="${1:?instance name required}"
  require_instance "$name"
  local cfg_dir="$INSTANCES_DIR/$name"

  if limactl list -q 2>/dev/null | grep -qx "$name"; then
    # Instance already exists: its config (mounts, resources, etc.) was
    # fixed at creation time. Just resume it -- passing a template file or
    # --cpus/--memory/--disk here makes limactl think we're (re)creating
    # the instance, which fails with "instance already exists".
    limactl start "$name"
  else
    local project_dir
    project_dir="$(cat "$cfg_dir/project-dir")"

    # Always create and mount a secrets dir, even if empty: mounts are
    # directory-level, so once it's mounted, files can be added or rotated
    # inside it later (via `claudevm secrets`) without ever needing a new
    # mount -- just a restart for provisioning to pick them up.
    mkdir -p "$cfg_dir/secrets"
    chmod 700 "$cfg_dir/secrets"

    # Render a per-instance config: the shared template plus an explicit
    # `mounts:` list, so the VM only ever sees the project dir and its own
    # config/secrets -- never Lima's built-in default mounts (which include
    # the host's home directory). Built via plain file concatenation, not a
    # CLI `--mount` flag, since that flag's accepted syntax isn't consistent
    # across Lima versions and silently falling back to Lima's defaults is
    # exactly what exposed the host home directory before this fix.
    local rendered="$cfg_dir/.lima.yaml"
    cp "$TEMPLATE" "$rendered"
    {
      echo
      echo "mounts:"
      echo "  - location: \"$project_dir\""
      echo "    mountPoint: \"/workspace\""
      echo "    writable: true"
      echo "  - location: \"$cfg_dir\""
      echo "    mountPoint: \"/mnt/claudevm-config\""
      echo "    writable: false"
      echo "  - location: \"$cfg_dir/secrets\""
      echo "    mountPoint: \"/mnt/claudevm-secrets\""
      echo "    writable: false"
    } >> "$rendered"

    limactl start --name="$name" --tty=false \
      --cpus="$CPUS" --memory="$MEMORY" --disk="$DISK" \
      "$rendered"
  fi

  close_ssh_control "$name"

  echo
  echo "'$name' is up. Project mounted at /workspace."
  echo "  Shell:  claudevm ssh $name"
  echo "  VS Code: claudevm code $name"
}

cmd_down() {
  local name="${1:?instance name required}"
  limactl stop "$name"
}

cmd_rm() {
  local name="${1:?instance name required}"
  read -r -p "Delete VM and config for '$name'? This cannot be undone. [y/N] " ans
  case "$ans" in
    y|Y) ;;
    *) echo "Aborted."; exit 0 ;;
  esac
  limactl stop "$name" 2>/dev/null || true
  limactl delete "$name" 2>/dev/null || true
  rm -rf "${INSTANCES_DIR:?}/$name"
  echo "Removed '$name'."
}

cmd_ssh() {
  local name="${1:?instance name required}"
  limactl shell --workdir /workspace "$name"
}

cmd_code() {
  local name="${1:?instance name required}"
  if ! command -v code >/dev/null 2>&1; then
    echo "The 'code' CLI isn't on your PATH. In VS Code: Cmd+Shift+P -> 'Shell Command: Install code command in PATH'." >&2
    exit 1
  fi
  code --remote "ssh-remote+lima-$name" /workspace
}

cmd_refresh() {
  local name="${1:?instance name required}"
  limactl shell "$name" -- sudo /usr/local/bin/update-firewall.sh
  echo "Firewall allowlist refreshed on '$name'."
}

cmd_allow() {
  local name="${1:?instance name required}"
  require_instance "$name"
  "${EDITOR:-vi}" "$INSTANCES_DIR/$name/allowlist.txt"
  echo "Saved. Apply now with: claudevm refresh $name  (otherwise it applies within 5 min)"
}

cmd_ls() {
  limactl list
}

cmd_secrets() {
  local name="${1:?instance name required}"
  require_instance "$name"

  local secrets_dir="$INSTANCES_DIR/$name/secrets"
  mkdir -p "$secrets_dir"
  chmod 700 "$secrets_dir"

  if [ ! -f "$secrets_dir/claude_oauth_token.txt" ]; then
    echo "No Claude Code token yet. On this HOST (not inside the VM), run:"
    echo "    claude setup-token"
    echo "Then paste the resulting token below (input hidden):"
    read -r -s token
    printf '%s' "$token" > "$secrets_dir/claude_oauth_token.txt"
    chmod 600 "$secrets_dir/claude_oauth_token.txt"
    echo
    echo "Saved."
  else
    echo "Claude Code token already saved for '$name'."
  fi
  echo

  if [ -f "$secrets_dir/gh_api_token.txt" ]; then
    read -r -p "GitHub API token already saved for '$name'. Replace it? [y/N] " gh_ans
  else
    read -r -p "Add a GitHub token for push/pull, PRs, and Issues/Projects access? [y/N] " gh_ans
  fi
  case "$gh_ans" in
    y|Y)
      echo "Create a fine-grained personal access token at:"
      echo "  https://github.com/settings/personal-access-tokens/new"
      echo "Scope it to this repo only, with:"
      echo "  Repository permissions -> Contents: Read and write      (git push/pull over HTTPS)"
      echo "  Repository permissions -> Pull requests: Read and write (open/manage PRs)"
      echo "  Repository permissions -> Issues: Read and write"
      echo "  Organization permissions -> Projects: Read and write"
      echo "(Projects access applies to every project your account/org owns --"
      echo "GitHub has no way to scope it to a single project board.)"
      echo
      echo "Also protect the target branch (e.g. main) with a branch protection rule"
      echo "requiring PRs, so this token can push feature branches but not merge directly."
      echo
      echo "Then paste the resulting token below (input hidden):"
      read -r -s gh_token
      printf '%s' "$gh_token" > "$secrets_dir/gh_api_token.txt"
      chmod 600 "$secrets_dir/gh_api_token.txt"
      echo
      echo "Saved. Restart the VM to pick it up: claudevm down $name && claudevm up $name"
      ;;
    *)
      echo "Skipped."
      ;;
  esac
  echo
  echo "Next: claudevm up $name"
}

main() {
  local cmd="${1:-}"
  [ -n "$cmd" ] || { usage; exit 1; }
  shift || true
  case "$cmd" in
    new) cmd_new "$@" ;;
    allow) cmd_allow "$@" ;;
    secrets) cmd_secrets "$@" ;;
    up) cmd_up "$@" ;;
    down) cmd_down "$@" ;;
    rm) cmd_rm "$@" ;;
    ssh) cmd_ssh "$@" ;;
    code) cmd_code "$@" ;;
    refresh) cmd_refresh "$@" ;;
    ls) cmd_ls "$@" ;;
    -h|--help|help) usage ;;
    *) echo "Unknown command: $cmd" >&2; usage; exit 1 ;;
  esac
}

main "$@"
